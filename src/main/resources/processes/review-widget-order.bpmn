      <bpmn:incoming>Flow_188wb72</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1sgzfo6" sourceRef="Activity_1vsfqos" targetRef="Event_08lc7rk" />
    <bpmn:sequenceFlow id="Flow_10z5jf3" name="Rejected" sourceRef="Gateway_07w16w7" targetRef="Activity_07feeik">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${order_approved == "false"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Activity_0qdytn8" name="Review Widget Order" camunda:formKey="review_showorder">
      <bpmn:incoming>Flow_1ev5nzi</bpmn:incoming>
      <bpmn:outgoing>Flow_0uqrhap</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:startEvent id="Event_1c5hcvh" name="Approve or Reject Widget order" camunda:initiator="WidgetOrderPlaced">
      <bpmn:outgoing>Flow_1ev5nzi</bpmn:outgoing>
      <bpmn:outgoing>Flow_1ov2tu5</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalEventDefinition_1tqgrl3" signalRef="Signal_202g113" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1ov2tu5" sourceRef="Event_1c5hcvh" targetRef="Activity_1vwo7wb" />
    <bpmn:serviceTask id="Activity_1vwo7wb" name="Notify new order to approve" camunda:delegateExpression="${NotifyOrderReadyForApproval}">
      <bpmn:incoming>Flow_1ov2tu5</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_188wb72" sourceRef="Activity_07feeik" targetRef="Event_08lc7rk" />
    <bpmn:sendTask id="Activity_07feeik" name="Notify customer rejected" camunda:delegateExpression="${NotifyCustomerRejected}">
      <bpmn:incoming>Flow_10z5jf3</bpmn:incoming>
      <bpmn:outgoing>Flow_188wb72</bpmn:outgoing>
    </bpmn:sendTask>
  </bpmn:process>
