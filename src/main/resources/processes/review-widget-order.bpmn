  <bpmn:process id="reviewWidgetOrder" name="ReviewWidgetOrder" isExecutable="true" camunda:historyTimeToLive="2">
    <bpmn:userTask id="Activity_1jvp1k3" name="Decide order outcome" camunda:formKey="review_decide">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0uqrhap</bpmn:incoming>
      <bpmn:outgoing>Flow_0pbhlyb</bpmn:outgoing>
