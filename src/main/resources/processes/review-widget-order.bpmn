  <bpmn:process id="review-widget-order" name="review-widget-order" isExecutable="true">
    <bpmn:startEvent id="Event_1c5hcvh" name="Approve or Reject Widget order" camunda:initiator="WidgetOrderPlaced">
      <bpmn:outgoing>Flow_1ev5nzi</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1vwfpvv" />
    </bpmn:startEvent>
    <bpmn:manualTask id="Activity_0qdytn8" name="Review Widget Order">
      <bpmn:incoming>Flow_1ev5nzi</bpmn:incoming>
      <bpmn:outgoing>Flow_0uqrhap</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Activity_1jvp1k3" name="Display Widget Details">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="order_approved">true</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0uqrhap</bpmn:incoming>
      <bpmn:outgoing>Flow_0pbhlyb</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1ev5nzi" sourceRef="Event_1c5hcvh" targetRef="Activity_0qdytn8" />
    <bpmn:sequenceFlow id="Flow_0uqrhap" sourceRef="Activity_0qdytn8" targetRef="Activity_1jvp1k3" />
    <bpmn:exclusiveGateway id="Gateway_07w16w7">
      <bpmn:incoming>Flow_0pbhlyb</bpmn:incoming>
      <bpmn:outgoing>Flow_15jr6ci</bpmn:outgoing>
      <bpmn:outgoing>Flow_10z5jf3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0pbhlyb" sourceRef="Activity_1jvp1k3" targetRef="Gateway_07w16w7" />
    <bpmn:sequenceFlow id="Flow_15jr6ci" name="Approved" sourceRef="Gateway_07w16w7" targetRef="Activity_1d02w3r">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${order_approved =="true"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Activity_07feeik">
      <bpmn:incoming>Flow_10z5jf3</bpmn:incoming>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_10z5jf3" name="Rejected" sourceRef="Gateway_07w16w7" targetRef="Activity_07feeik">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${order_approved == "false"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_1d02w3r" name="Provision widget">
      <bpmn:incoming>Flow_15jr6ci</bpmn:incoming>
      <bpmn:outgoing>Flow_1l76943</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1l76943" sourceRef="Activity_1d02w3r" targetRef="Activity_1vsfqos" />
    <bpmn:sendTask id="Activity_1vsfqos" name="Notify Customer">
      <bpmn:incoming>Flow_1l76943</bpmn:incoming>
      <bpmn:outgoing>Flow_1sgzfo6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_08lc7rk">
      <bpmn:incoming>Flow_1sgzfo6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1sgzfo6" sourceRef="Activity_1vsfqos" targetRef="Event_08lc7rk" />
  </bpmn:process>
