    <bpmn:sendTask id="Activity_1vsfqos" name="Notify Customer" camunda:delegateExpression="${NotifyCustomerApproved}">
      <bpmn:incoming>Flow_1l76943</bpmn:incoming>
      <bpmn:outgoing>Flow_1sgzfo6</bpmn:outgoing>
    </bpmn:sendTask>
